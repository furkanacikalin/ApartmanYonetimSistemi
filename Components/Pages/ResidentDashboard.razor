@page "/resident-dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ApartmanYonetimSistemi.Models
@using ApartmanYonetimSistemi.Data
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Roles = "Resident")]
@inject IDbContextFactory<UserContext> UserCtxFactory
@inject IDbContextFactory<FlatContext> FlatCtxFactory
@inject IDbContextFactory<ApartmentContext> AptCtxFactory
@inject IDbContextFactory<AnnouncementContext> AnnCtxFactory
@inject IDbContextFactory<PaymentContext> PayCtxFactory

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark">Sakin Paneli</h2>
            <p class="text-muted">Hoş geldiniz, dairenizle ilgili güncel bilgilere buradan ulaşabilirsiniz.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Yükleniyor...</span>
            </div>
        </div>
    }
    
    else
    {
            <div class="row">
                
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 border-0">
                        <div class="card-header bg-white fw-bold py-3">
                            <i class="bi bi-house-door text-primary me-2"></i>Daire Bilgilerim
                        </div>
                        <div class="card-body">
                            @if (residentFlat != null)
                            {
                                <div class="row g-3">
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Apartman</label>
                                        <span class="fw-bold">@belongingApartment?.Name</span>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Daire No</label>
                                        <span class="fw-bold">@residentFlat.FlatNumber</span>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Kat</label>
                                        <span class="fw-bold">@residentFlat.Floor</span>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted d-block">Blok/Bölüm</label>
                                        <span class="fw-bold">@residentFlat.Block</span>
                                    </div>
                                    <div class="col-12">
                                        <label class="small text-muted d-block">Apartman Adresi</label>
                                        <span class="fw-bold">@(belongingApartment?.Address ?? "Adres bilgisi girilmemiş.")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 border-0">
                        <div class="card-header bg-white fw-bold py-3 d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-megaphone text-primary me-2"></i>Son Duyurular</span>
                            @if (latestAnnouncements.Any())
                            {
                                <span class="badge bg-primary rounded-pill">@latestAnnouncements.Count</span>
                            }
                        </div>
                        <div class="card-body">
                            @if (latestAnnouncements.Any())
                            {
                                <div class="list-group list-group-flush mb-3">
                                    @foreach (var ann in latestAnnouncements)
                                    {
                                        <div class="list-group-item px-0 border-0 border-bottom mb-2 pb-2">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h6 class="mb-1 fw-bold text-dark">@ann.Title</h6>
                                                <small class="text-muted" style="font-size: 0.7rem;">@ann.CreatedDate.ToString("dd MMM HH:mm")</small>
                                            </div>
                                            <p class="mb-1 text-muted small text-truncate">@ann.Content</p>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            
            <div class="row mb-4">
                <div class="col-12">
                    @if (totalUnpaid > 0)
                    {
                        <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center p-3 animate__animated animate__pulse">
                            <i class="bi bi-exclamation-triangle-fill fs-3 me-3 text-warning"></i>
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-bold">Ödeme Hatırlatması</h6>
                                <small>Toplam <strong>@totalUnpaid.ToString("C2")</strong> tutarında bekleyen borcunuz bulunmaktadır.</small>
                            </div>
                            <a href="/my-payments" class="btn btn-warning btn-sm fw-bold shadow-sm">
                                Ödemelere Git <i class="bi bi-arrow-right-short"></i>
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success border-0 shadow-sm d-flex align-items-center p-3">
                            <i class="bi bi-check-circle-fill fs-3 me-3 text-success"></i>
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-bold">Borcunuz Bulunmuyor</h6>
                                <small>Tüm ödemeleriniz günceldir, teşekkür ederiz!</small>
                            </div>
                        </div>
                    }
                </div>
            </div>

        
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm border-0 bg-light">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <i class="bi bi-person-circle fs-3 text-secondary me-3"></i>
                            <span class="fw-bold">@currentUser?.FirstName @currentUser?.LastName</span>
                            <span class="text-muted mx-2">|</span>
                            <span class="small">@currentUser?.Username</span>
                        </div>
                        <a href="/profile" class="btn btn-sm btn-outline-secondary">
                            Profilimi Düzenle
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private User? currentUser;
    private Flat? residentFlat;
    private Apartment? belongingApartment;
    private List<Announcement> latestAnnouncements = new();
    private decimal totalUnpaid = 0;

    [CascadingParameter] private Task<AuthenticationState> authState { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        await LoadResidentData();
    }

    private async Task LoadResidentData()
    {
        var auth = await authState;
        var userIdClaim = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(userIdClaim, out int userId))
        {
            
            using (var userCtx = await UserCtxFactory.CreateDbContextAsync())
            {
                currentUser = await userCtx.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Id == userId);
            }

            
            using (var flatCtx = await FlatCtxFactory.CreateDbContextAsync())
            {
                residentFlat = await flatCtx.Flats.AsNoTracking().FirstOrDefaultAsync(f => f.ResidentUserId == userId);
            }

            if (residentFlat != null)
            {
                
                using (var aptCtx = await AptCtxFactory.CreateDbContextAsync())
                {
                    belongingApartment = await aptCtx.Apartments.AsNoTracking().FirstOrDefaultAsync(a => a.Id == residentFlat.ApartmentId);
                }

                
                using (var annCtx = await AnnCtxFactory.CreateDbContextAsync())
                {
                    latestAnnouncements = await annCtx.Announcements
                        .AsNoTracking()
                        .Where(a => a.ApartmentId == residentFlat.ApartmentId)
                        .OrderByDescending(a => a.UpdatedDate ?? a.CreatedDate)
                        .Take(3)
                        .ToListAsync();
                }

                
                using (var payCtx = await PayCtxFactory.CreateDbContextAsync())
                {
                    totalUnpaid = await payCtx.Payments
                        .Where(p => p.FlatId == residentFlat.Id && !p.IsPaid)
                        .SumAsync(p => p.Amount);
                }
            }
        }

        isLoading = false;
    }
}