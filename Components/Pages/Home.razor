@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<div class="container text-center mt-5">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border-top border-primary border-5">
        <div class="container-fluid py-5">
            <i class="bi bi-building-check display-1 text-primary mb-4"></i>
            <h1 class="display-5 fw-bold">Apartman Yönetim Sistemi'ne Hoş Geldiniz</h1>
            <p class="col-md-8 fs-4 mx-auto text-muted">
                Apartmanınızı dijital ortamda kolayca yönetmek, sakinlerinizi takip etmek ve finansal süreçleri kontrol altına almak için doğru yerdesiniz.
            </p>

            <AuthorizeView Context="authContext">
                <Authorized>
                    <div class="mt-4">
                        <div class="alert alert-info d-inline-block px-4 py-2 rounded-pill">
                            <i class="bi bi-person-check-fill me-2"></i>
                            Hoş geldin, <strong>@authContext.User.Identity?.Name</strong>
                        </div>
                        <div class="mt-3">
                            <a href="@(authContext.User.IsInRole("Admin") ? "/dashboard" : "/resident-dashboard")"
                               class="btn btn-primary btn-lg px-4 fw-bold shadow-sm">
                                <i class="bi bi-speedometer2 me-2"></i>Panele Git
                            </a>
                        </div>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <p class="mt-4 text-secondary">Yönetim işlemlerine başlamak veya dairenizi görüntülemek için lütfen giriş yapın.</p>
                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-3">
                        <a href="/login" class="btn btn-primary btn-lg px-5 shadow-sm fw-bold">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                        </a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>