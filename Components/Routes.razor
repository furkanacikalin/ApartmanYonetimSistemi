@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavManager

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(ApartmanYonetimSistemi.Components.Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                       
                        <NavigationRedirect Url="/" />
                    }
                    else
                    {
                        
                        <div class="container mt-5">
                            <div class="alert alert-warning shadow-sm">
                                <h4 class="alert-heading"><i class="bi bi-exclamation-octagon me-2"></i>Erişim Engellendi</h4>
                                <p>Bu sayfaya erişim yetkiniz bulunmuyor. Ana sayfaya yönlendiriliyorsunuz...</p>
                            </div>
                        </div>
                        <NavigationRedirect Url="/" />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(ApartmanYonetimSistemi.Components.Layout.MainLayout)">
                <div class="container mt-5 text-center">
                    <i class="bi bi-search-heart display-1 text-muted"></i>
                    <p class="mt-3 fs-4" role="alert">Üzgünüz, aradığınız adres bulunamadı.</p>
                    <a href="/" class="btn btn-outline-primary">Ana Sayfaya Dön</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
   
    private class NavigationRedirect : ComponentBase
    {
        [Inject] public NavigationManager Nav { get; set; } = default!;
        [Parameter] public string Url { get; set; } = "/";

        protected override void OnInitialized()
        {
            Nav.NavigateTo(Url);
        }
    }
}